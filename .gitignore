# ==========================
# Global
# ==========================
.DS_Store
Thumbs.db

.vscode/
.idea/
*.swp
*.swo
*.tmp
.claude/

# env — keep .env.example tracked
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

dist/
build/
.cache/
tmp/
*.bak

# ==========================
# Backend (Go)
# ==========================
/backend/bin/
/backend/tmp/
/backend/api
/backend/.env
/backend/.env.*
!backend/.env.example
/backend/*.log
/backend/coverage/
/backend/tests/testdata/
/backend/database/*.db
/backend/storage/
/backend/vendor/
/backend/*.out

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.coverprofile
*.cov

# ==========================
# Frontend (Next.js / Node)
# ==========================
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.turbo/
/frontend/.vercel/
/frontend/.env
/frontend/.env.*
!frontend/.env.example
/frontend/coverage/
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/.eslintcache
/frontend/.stylelintcache

# ==========================
# Storage
# ==========================
/storage/*
!/storage/.gitkeep

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Secrets / Certs
# ==========================
*.pem
*.crt
*.key
